{
  "name": "@thuum/decor",
  "version": "0.0.2",
  "description": "Type-safe function decorator toolkit for aspect-oriented programming — build reusable, composable patterns for observability, resilience, and flow control in TypeScript",
  "keywords": [
    "decorator",
    "aspect-oriented-programming",
    "aop",
    "cross-cutting-concerns",
    "observability",
    "resilience",
    "flow-control",
    "guard",
    "middleware",
    "higher-order-function",
    "wrapper",
    "composable",
    "retry",
    "circuit-breaker",
    "throttle",
    "debounce",
    "memoize",
    "tracing",
    "error-handling",
    "functional",
    "typescript"
  ],
  "author": {
    "name": "Jalepi",
    "url": "https://github.com/jalepi"
  },
  "license": "ISC",
  "homepage": "https://jalepi.github.io/thuum/packages/decor",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jalepi/thuum.git",
    "directory": "packages/decor"
  },
  "bugs": {
    "url": "https://github.com/jalepi/thuum/issues"
  },
  "scripts": {
    "build": "tsc -p ./tsconfig.cjs.json && tsc -p ./tsconfig.esm.json",
    "build:esm": "tsc -p ./tsconfig.esm.json",
    "build:cjs": "tsc -p ./tsconfig.cjs.json",
    "release": "bun publish",
    "release:dry": "bun publish --dry-run",
    "release:pack": "bun pm pack"
  },
  "devDependencies": {
    "@types/bun": "catalog:dev",
    "tslib": "catalog:dev",
    "typescript": "catalog:dev"
  },
  "type": "module",
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/esm/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/esm/index.d.ts",
        "default": "./dist/esm/index.js"
      },
      "require": {
        "types": "./dist/cjs/index.d.ts",
        "default": "./dist/cjs/index.js"
      }
    },
    "./async": {
      "import": {
        "types": "./dist/esm/async/index.d.ts",
        "default": "./dist/esm/async/index.js"
      },
      "require": {
        "types": "./dist/cjs/async/index.d.ts",
        "default": "./dist/cjs/async/index.js"
      }
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "package.json"
  ],
  "publishConfig": {
    "access": "public"
  }
}
