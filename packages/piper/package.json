{
  "name": "@thuum/piper",
  "version": "0.0.1",
  "description": "Functional programming utilities for pipe operations and function composition with async support",
  "keywords": [
    "pipe",
    "compose",
    "functional",
    "chain",
    "transform",
    "async",
    "typescript",
    "fp"
  ],
  "author": "Jalepi",
  "license": "ISC",
  "homepage": "https://jalepi.github.io/thuum/packages/piper",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jalepi/thuum.git",
    "directory": "packages/piper"
  },
  "scripts": {
    "build": "tsc -p ./tsconfig.cjs.json && tsc -p ./tsconfig.esm.json",
    "build:esm": "tsc -p ./tsconfig.esm.json",
    "build:cjs": "tsc -p ./tsconfig.cjs.json"
  },
  "devDependencies": {
    "tslib": "catalog:dev",
    "typescript": "catalog:dev"
  },
  "type": "module",
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/esm/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/esm/index.d.ts",
        "default": "./dist/esm/index.js"
      },
      "require": {
        "types": "./dist/cjs/index.d.ts",
        "default": "./dist/cjs/index.js"
      }
    },
    "./async-pipe": {
      "import": {
        "types": "./dist/esm/async-pipe.d.ts",
        "default": "./dist/esm/async-pipe.js"
      },
      "require": {
        "types": "./dist/cjs/async-pipe.d.ts",
        "default": "./dist/cjs/async-pipe.js"
      }
    },
    "./async-build": {
      "import": {
        "types": "./dist/esm/async-build.d.ts",
        "default": "./dist/esm/async-build.js"
      },
      "require": {
        "types": "./dist/cjs/async-build.d.ts",
        "default": "./dist/cjs/async-build.js"
      }
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "package.json"
  ]
}
