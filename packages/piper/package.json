{
  "name": "@thuum/piper",
  "version": "0.0.2",
  "description": "Functional programming utilities for pipe operations and function composition with async support",
  "keywords": [
    "pipe",
    "pipeline",
    "compose",
    "function-composition",
    "functional",
    "fp",
    "fluent",
    "chain",
    "transform",
    "data-transformation",
    "builder",
    "async",
    "typescript",
    "type-safe"
  ],
  "author": {
    "name": "Jalepi",
    "url": "https://github.com/jalepi"
  },
  "license": "ISC",
  "homepage": "https://jalepi.github.io/thuum/packages/piper",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jalepi/thuum.git",
    "directory": "packages/piper"
  },
  "bugs": {
    "url": "https://github.com/jalepi/thuum/issues"
  },
  "scripts": {
    "build": "tsc -p ./tsconfig.cjs.json && tsc -p ./tsconfig.esm.json",
    "build:esm": "tsc -p ./tsconfig.esm.json",
    "build:cjs": "tsc -p ./tsconfig.cjs.json",
    "release": "bun publish",
    "release:dry": "bun publish --dry-run",
    "release:pack": "bun pm pack"
  },
  "devDependencies": {
    "tslib": "catalog:dev",
    "typescript": "catalog:dev"
  },
  "type": "module",
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/esm/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/esm/index.d.ts",
        "default": "./dist/esm/index.js"
      },
      "require": {
        "types": "./dist/cjs/index.d.ts",
        "default": "./dist/cjs/index.js"
      }
    },
    "./async": {
      "import": {
        "types": "./dist/esm/async/index.d.ts",
        "default": "./dist/esm/async/index.js"
      },
      "require": {
        "types": "./dist/cjs/async/index.d.ts",
        "default": "./dist/cjs/async/index.js"
      }
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "package.json"
  ],
  "publishConfig": {
    "access": "public"
  }
}
