{
  "version": "0.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "build": "bun --verbose --filter '*' build",
    "build:ci": "bun run build && bun run format && bun run lint",
    "lint": "eslint . --cache --report-unused-disable-directives --max-warnings 0",
    "format": "prettier --check --cache '**/*.{cjs,mjs,js,jsx,cts,mts,ts,tsx,json}'",
    "format:fix": "prettier --write '**/*.{cjs,mjs,js,jsx,cts,mts,ts,tsx,json}'",
    "test": "bun test packages",
    "test:watch": "bun test packages --watch",
    "test:ci": "bun test packages --reporter=junit --reporter-outfile=./test-results/junit.xml --coverage",
    "docs:dev": "cd docs && bun run dev",
    "docs:build": "cd docs && bun run build"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@eslint/js": "catalog:dev",
    "@happy-dom/global-registrator": "catalog:dev",
    "@types/bun": "catalog:dev",
    "eslint": "catalog:dev",
    "eslint-config-prettier": "catalog:dev",
    "eslint-plugin-prettier": "catalog:dev",
    "globals": "catalog:dev",
    "happy-dom": "catalog:dev",
    "prettier": "catalog:dev",
    "tslib": "catalog:dev",
    "typescript": "catalog:dev",
    "typescript-eslint": "catalog:dev"
  },
  "workspaces": {
    "packages": [
      "packages/*",
      "docs"
    ],
    "catalogs": {
      "dev": {
        "@eslint/js": "^10.0.1",
        "@happy-dom/global-registrator": "^20.9.0",
        "@types/bun": "^1.3.12",
        "eslint": "^10.2.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-prettier": "^5.5.4",
        "globals": "^17.5.0",
        "happy-dom": "^20.9.0",
        "prettier": "^3.8.2",
        "tslib": "^2.8.1",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.50.2"
      }
    }
  }
}
